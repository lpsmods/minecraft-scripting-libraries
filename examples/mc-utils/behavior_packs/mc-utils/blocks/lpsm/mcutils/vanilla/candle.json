{
  "format_version": "1.26.20",
  "minecraft:block": {
    "description": {
      "identifier": "lpsmods:candle",
      "menu_category": {
        "category": "none"
      },
      "states": {
        "mcutils:candles": [1, 2, 3, 4],
        "mcutils:lit": [false, true]
      }
    },
    "components": {
      "minecraft:tags": ["non_full"],
      "minecraft:geometry": {
        "identifier": "geometry.lpsm_assetsplus_candle",
        "bone_visibility": {
          "one": "q.block_state('mcutils:candles')==1",
          "two": "q.block_state('mcutils:candles')==2",
          "three": "q.block_state('mcutils:candles')==3",
          "four": "q.block_state('mcutils:candles')==4"
        }
      },
      "minecraft:material_instances": {
        "*": {
          "texture": "lpsmods:candle",
          "face_dimming": false
        }
      },
      "minecraft:liquid_detection": {
        "detection_rules": [
          {
            "can_contain_liquid": true,
            "liquid_type": "water"
          }
        ]
      },
      "minecraft:tick": {
        "interval_range": [0, 0]
      },
      "mcutils:candle": {
        "item": "lpsmods:candle",
        "candles_state": "mcutils:candles",
        "lit_state": "mcutils:lit",
        "max_candles": 4,
        "flame_positions": [
          "1,0,8,0",
          "2,2,8,-1",
          "2,-2,7,0",
          "3,1,8,-1",
          "3,-2,7,0",
          "3,0,5,2",
          "4,1,8,-2",
          "4,-2,7,-2",
          "4,2,7,1",
          "4,-1,5,1"
        ],
        "flame_particle": "minecraft:candle_flame_particle"
      }
    },
    "permutations": [
      {
        "condition": "q.block_state('mcutils:lit')",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "lpsmods:candle_lit",
              "face_dimming": false
            }
          }
        }
      },
      {
        "condition": "q.block_state('mcutils:lit')&&q.block_state('mcutils:candles')==1",
        "components": {
          "minecraft:light_emission": 3
        }
      },
      {
        "condition": "q.block_state('mcutils:lit')&&q.block_state('mcutils:candles')==2",
        "components": {
          "minecraft:light_emission": 6
        }
      },
      {
        "condition": "q.block_state('mcutils:lit')&&q.block_state('mcutils:candles')==3",
        "components": {
          "minecraft:light_emission": 9
        }
      },
      {
        "condition": "q.block_state('mcutils:lit')&&q.block_state('mcutils:candles')==4",
        "components": {
          "minecraft:light_emission": 12
        }
      },
      {
        "condition": "q.block_state('mcutils:candles')==1",
        "components": {
          "minecraft:selection_box": {
            "origin": [-1, 0, -1],
            "size": [2, 6, 2]
          },
          "minecraft:collision_box": {
            "origin": [-1, 0, -1],
            "size": [2, 6, 2]
          }
        }
      },
      {
        "condition": "q.block_state('mcutils:candles')==2",
        "components": {
          "minecraft:selection_box": {
            "origin": [-3, 0, -2],
            "size": [6, 6, 3]
          },
          "minecraft:collision_box": {
            "origin": [-3, 0, -2],
            "size": [6, 6, 3]
          }
        }
      },
      {
        "condition": "q.block_state('mcutils:candles')==3",
        "components": {
          "minecraft:selection_box": {
            "origin": [-2, 0, -2],
            "size": [5, 6, 5]
          },
          "minecraft:collision_box": {
            "origin": [-2, 0, -2],
            "size": [5, 6, 5]
          }
        }
      },
      {
        "condition": "q.block_state('mcutils:candles')==4",
        "components": {
          "minecraft:selection_box": {
            "origin": [-3, 0, -3],
            "size": [6, 6, 5]
          },
          "minecraft:collision_box": {
            "origin": [-3, 0, -3],
            "size": [6, 6, 5]
          }
        }
      }
    ]
  }
}
