{
  "format_version": "1.26.20",
  "minecraft:block": {
    "description": {
      "identifier": "lpsmods:candle_cake",
      "states": {
        "mcutils:lit": [false, true]
      },
      "menu_category": {
        "category": "none"
      }
    },
    "components": {
      "minecraft:geometry": "geometry.lpsm_assetsplus_cake_with_candle",
      "minecraft:material_instances": {
        "*": {
          "texture": "lpsmods:candle_cake"
        }
      },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 0.5
      },
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0.5
      },
      "minecraft:selection_box": {
        "origin": [-7, 0, -7],
        "size": [14, 8, 14]
      },
      "minecraft:collision_box": {
        "origin": [-7, 0, -7],
        "size": [14, 8, 14]
      },
      "minecraft:tick": {
        "interval_range": [0, 0]
      },
      "mcutils:candle_cake": {
        "candle": "minecraft:candle",
        "block": "lpsmods:cake",
        "lit_state": "mcutils:lit",
        "slice_state": "mcutils:slice",
        "flame_position": [0, 16, 0],
        "flame_particle": "minecraft:candle_flame_particle"
      }
    },
    "permutations": [
      {
        "condition": "q.block_state('mcutils:lit') == false",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "minecraft:cake_bottom",
              "render_method": "opaque"
            },
            "side": {
              "texture": "minecraft:cake_side",
              "render_method": "opaque"
            },
            "candle": {
              "texture": "minecraft:candle",
              "render_method": "opaque"
            },
            "up": {
              "texture": "minecraft:cake_top",
              "render_method": "opaque"
            }
          }
        }
      },
      {
        "condition": "q.block_state('mcutils:lit') == true",
        "components": {
          "minecraft:light_emission": 3,
          "minecraft:material_instances": {
            "*": {
              "texture": "minecraft:cake_bottom",
              "render_method": "opaque"
            },
            "side": {
              "texture": "minecraft:cake_side",
              "render_method": "opaque"
            },
            "candle": {
              "texture": "minecraft:candle_lit",
              "render_method": "opaque"
            },
            "up": {
              "texture": "minecraft:cake_top",
              "render_method": "opaque"
            }
          }
        }
      }
    ]
  }
}
