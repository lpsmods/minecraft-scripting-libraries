{
  "format_version": "1.26.20",
  "minecraft:block": {
    "description": {
      "identifier": "lpsmods:bush",
      "states": {
        "mcutils:growth": [0, 1, 2, 3]
      },
      "menu_category": {
        "category": "none"
      }
    },
    "components": {
      "minecraft:tags": ["plant", "fertilizable"],
      "minecraft:loot": "loot_tables/lpsmods/blocks/bush.json",
      "minecraft:light_dampening": 0,
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0
      },
      "minecraft:destructible_by_explosion": {
        "explosion_resistance": 0
      },
      "minecraft:collision_box": false,
      "minecraft:geometry": "minecraft:geometry.cross",
      "minecraft:material_instances": {
        "*": {
          "texture": "lpsmods:bush_stage_0",
          "render_method": "alpha_test_single_sided",
          "face_dimming": false
        }
      },
      "minecraft:placement_filter": {
        "conditions": [
          {
            "block_filter": [
              "minecraft:grass_block",
              "minecraft:dirt",
              "minecraft:podzol",
              {
                "tags": "q.any_tag('dirt','grass') && !q.any_tag('non_full')"
              }
            ],
            "allowed_faces": ["up"]
          }
        ]
      },
      "minecraft:liquid_detection": {
        "detection_rules": [
          {
            "can_contain_liquid": false,
            "liquid_type": "water",
            "on_liquid_touches": "popped"
          }
        ]
      },
      "minecraft:selection_box": {
        "origin": [-3.2, 0, -3.2],
        "size": [6.4, 8, 6.4]
      },
      "minecraft:tick": {
        "interval_range": [0, 0]
      },
      "mcutils:bush": {
        "growth_state": "mcutils:growth",
        // "item": "lpsmods:berries",
        "loot_tables": ["2,lpsmods/harvest/bush_2", "3,lpsmods/harvest/bush_3"]
      },
      "mcutils:crop": {
        "growth_state": "mcutils:growth",
        "max_stage": 3
      },
      "mcutils:fertilizable": {
        "growth_state": "mcutils:growth",
        "max_stage": 3
      },
      "mcutils:viscosity": -5
    },
    "permutations": [
      {
        "condition": "q.block_state('mcutils:growth') == 1",
        "components": {
          "minecraft:destructible_by_mining": {
            "seconds_to_destroy": 0.3
          },
          "minecraft:selection_box": {
            "origin": [-6.2, 0, -6.2],
            "size": [12.4, 16, 12.4]
          },
          "minecraft:material_instances": {
            "*": {
              "texture": "lpsmods:bush_stage_1",
              "render_method": "alpha_test_single_sided",
              "face_dimming": false
            }
          }
        }
      },
      {
        "condition": "q.block_state('mcutils:growth') == 2",
        "components": {
          "minecraft:loot": "loot_tables/lpsmods/harvest/bush_2.json",
          "minecraft:destructible_by_mining": {
            "seconds_to_destroy": 0.3
          },
          "minecraft:selection_box": {
            "origin": [-6.2, 0, -6.2],
            "size": [12.4, 16, 12.4]
          },
          "minecraft:material_instances": {
            "*": {
              "texture": "lpsmods:bush_stage_2",
              "render_method": "alpha_test_single_sided",
              "face_dimming": false
            }
          }
        }
      },
      {
        "condition": "q.block_state('mcutils:growth') == 3",
        "components": {
          "minecraft:loot": "loot_tables/lpsmods/harvest/bush_3.json",
          "minecraft:destructible_by_mining": {
            "seconds_to_destroy": 0.3
          },
          "minecraft:selection_box": {
            "origin": [-6.2, 0, -6.2],
            "size": [12.4, 16, 12.4]
          },
          "minecraft:material_instances": {
            "*": {
              "texture": "lpsmods:bush_stage_3",
              "render_method": "alpha_test_single_sided",
              "face_dimming": false
            }
          }
        }
      }
    ]
  }
}
