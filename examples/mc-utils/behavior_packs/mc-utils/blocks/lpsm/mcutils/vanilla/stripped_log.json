          "minecraft:transformation": {
            "rotation": [90, 0, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:block_face')=='south'",
        "components": {
          "minecraft:transformation": {
            "rotation": [90, 180, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:block_face')=='east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [90, -90, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:block_face')=='west'",
        "components": {
          "minecraft:transformation": {
            "rotation": [90, 90, 0]
          }
        }
      }
    ]
  }
}
