{
  "format_version": "1.26.20",
  "minecraft:block": {
    "description": {
      "identifier": "lpsmods:fence_gate",
      "menu_category": {
        "category": "construction",
        "group": "lpsmods:itemGroup.name.fenceGate"
      },
      "states": {
        "mcutils:open": [false, true],
        "mcutils:in_wall": [false, true]
      },
      "traits": {
        "minecraft:placement_direction": {
          "enabled_states": ["minecraft:cardinal_direction"]
        }
      }
    },
    "components": {
      "minecraft:tags": ["minecraft:wall", "one_way_collidable"],
      "minecraft:material_instances": {
        "*": {
          "texture": "minecraft:oak_planks"
        }
      },
      "minecraft:geometry": {
        "identifier": "geometry.lpsm_assetsplus_fence_gate",
        "bone_visibility": {
          "default": "!q.block_state('mcutils:in_wall')",
          "in_wall": "q.block_state('mcutils:in_wall')"
        }
      },
      "minecraft:tick": {
        "interval_range": [0, 0],
        "looping": true
      },
      "minecraft:liquid_detection": {
        "detection_rules": [
          {
            "can_contain_liquid": true,
            "liquid_type": "water"
          }
        ]
      },
      "minecraft:collision_box": {
        "origin": [-8, 0, -2],
        "size": [16, 16, 4]
      },
      "minecraft:selection_box": {
        "origin": [-8, 0, -2],
        "size": [16, 16, 4]
      },
      "mcutils:fence_gate": {
        "toggle_state": "mcutils:open",
        "in_wall_state": "mcutils:in_wall",
        "direction_state": "minecraft:cardinal_direction",
        "true_sound_event": "open.fence_gate",
        "false_sound_event": "close.fence_gate"
      }
    },
    "permutations": [
      {
        "condition": "q.block_state('mcutils:open')",
        "components": {
          "minecraft:geometry": {
            "identifier": "geometry.lpsm_assetsplus_fence_gate.open",
            "bone_visibility": {
              "default": "!q.block_state('mcutils:in_wall')",
              "in_wall": "q.block_state('mcutils:in_wall')"
            }
          },
          "minecraft:collision_box": false
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction')=='north'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 0, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction')=='south'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 180, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction')=='east'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, -90, 0]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:cardinal_direction')=='west'",
        "components": {
          "minecraft:transformation": {
            "rotation": [0, 90, 0]
          }
        }
      }
    ]
  }
}
