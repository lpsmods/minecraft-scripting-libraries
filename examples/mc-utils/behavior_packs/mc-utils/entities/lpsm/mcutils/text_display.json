{
  "format_version": "1.16.0",
  "minecraft:entity": {
    "description": {
      "identifier": "lpsmods:text_display",
      "is_spawnable": false,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "lpsmods:despawn": { "minecraft:instant_despawn": {} }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["floating_text", "hologram", "inanimate"]
      },
      "minecraft:fire_immune": {},
      "minecraft:collision_box": { "width": 0.0, "height": 0.0 },
      "minecraft:persistent": {},
      "minecraft:damage_sensor": { "triggers": [{ "deals_damage": "no" }] },
      "minecraft:physics": { "has_gravity": false, "has_collision": false },
      "minecraft:nameable": {
        "always_show": true,
        "allow_name_tag_renaming": false
      },
      "minecraft:custom_hit_test": {
        "hitboxes": [{ "width": 1, "height": 1, "pivot": [0, 0, 0] }]
      },
      "minecraft:conditional_bandwidth_optimization": {},
      "minecraft:knockback_resistance": {
        "value": 1,
        "max": 1
      },
      "minecraft:interact": {
        "interactions": [
          {
            "on_interact": {
              "filters": [
                {
                  "all_of": [
                    {
                      "test": "has_tag",
                      "subject": "self",
                      "operator": "!=",
                      "value": "locked"
                    },
                    {
                      "test": "is_sneaking",
                      "subject": "other",
                      "operator": "==",
                      "value": false
                    }
                  ]
                }
              ]
            },
            "interact_text": "Rename",
            "swing": true
          }
        ]
      }
    },
    "events": {
      "lpsmods:despawn": { "add": { "component_groups": ["lpsmods:despawn"] } }
    }
  }
}
