{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2021"],
    "strict": true,
    "outDir": "./dist",
    "rootDir": "src",
    "skipLibCheck": false,
    "types": ["@minecraft/server", "@minecraft/server-ui"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
